rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for validating primitive attributes
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Locations Collection: warehouses and storefronts
    match /locations/{locationId} {
      allow read: if true;
      allow create, update: if isValidId(locationId) 
        && request.resource.data.id == locationId
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && (request.resource.data.type == 'warehouse' || request.resource.data.type == 'store');
      allow delete: if true;
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isValidId(productId)
        && request.resource.data.id == productId
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100
        && request.resource.data.category is string
        && request.resource.data.category.size() <= 50;
      allow delete: if true;
    }

    // Varieties Collection
    match /varieties/{varietyId} {
      allow read: if true;
      allow create, update: if isValidId(varietyId)
        && request.resource.data.id == varietyId
        && request.resource.data.productId is string
        && request.resource.data.varietyName is string
        && request.resource.data.varietyName.size() <= 100
        && request.resource.data.sku is string
        && request.resource.data.sku.size() <= 50
        && request.resource.data.costPrice is number
        && request.resource.data.sellingPrice is number;
      allow delete: if true;
    }

    // Stock levels mapped by varietyId_locationId
    match /stock/{stockId} {
      allow read: if true;
      allow create, update: if stockId.matches('^[a-zA-Z0-9_\\-]+_[a-zA-Z0-9_\\-]+$')
        && request.resource.data.varietyId is string
        && request.resource.data.locationId is string
        && request.resource.data.quantity is int
        && request.resource.data.quantity >= 0;
      allow delete: if true;
    }

    // Ledger transactions (receives, transfers, adjustments, sales)
    match /transactions/{transactionId} {
      allow read: if true;
      allow create, update: if isValidId(transactionId)
        && request.resource.data.id == transactionId
        && request.resource.data.type is string
        && request.resource.data.sku is string
        && request.resource.data.quantity is int
        && request.resource.data.reportedBy is string
        && request.resource.data.reportedBy.size() <= 100;
      allow delete: if true;
    }

    // Category Hierarchy Trees
    match /categoryTree/{nodeId} {
      allow read: if true;
      allow create, update: if isValidId(nodeId)
        && request.resource.data.id == nodeId
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 100;
      allow delete: if true;
    }
  }
}
